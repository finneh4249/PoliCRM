DATABASE_URL=sqlite://crm.db

# NationBuilder
NATIONBUILDER_API_KEY=<your_api_key>
NATIONBUILDER_SLUG=futureparty

# AES-256-GCM encryption key for all PII fields.
# Must be a consistent string — changing this WILL make existing encrypted data unreadable.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=<generate_with_openssl_rand_base64_32>
